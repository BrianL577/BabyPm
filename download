# Copy this file to .env.local for local testing.
# In production (Vercel), set these as Environment Variables in the project
# settings instead of committing a real .env file.

# Anthropic API key used by the demo's chat/report/email/tender endpoints.
# Get one at https://console.anthropic.com  (Account > API Keys)
ANTHROPIC_API_KEY=

# Optional: override the default model. Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase project credentials (Project Settings > API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
